# ==========================================================================
# Portal Logístico — variáveis de ambiente
# Copie este arquivo para ".env" e preencha conforme necessário.
# ==========================================================================

# ----- Banco de dados (PostgreSQL) ----------------------------------------
# Para hospedagem gratuita e permanente use o Neon (https://neon.tech) — Postgres
# grátis, sem cartão. No painel do Neon, copie as DUAS strings de conexão:
#   • "Pooled connection" (tem "-pooler" no host) -> DATABASE_URL
#   • "Direct connection" (sem "-pooler")         -> DIRECT_URL
# Acrescente ?sslmode=require ao final de ambas, se ainda não tiver.
#
# DATABASE_URL = usada pela aplicação (conexão pooled, ideal p/ serverless).
# DIRECT_URL   = usada por "prisma db push"/migrations (conexão direta).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGIAO.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGIAO.aws.neon.tech/neondb?sslmode=require"

# Segredo usado para assinar os tokens de sessão (JWT). Troque por um valor
# aleatório longo em produção. Gere um com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="troque-este-segredo-por-um-valor-aleatorio-bem-grande"

# ----- E-mail (SMTP) -------------------------------------------------------
# Se NÃO preenchido, as notificações de e-mail rodam em MODO SIMULADO
# (apenas registradas no banco, sem envio real).
#
# Gmail (mais simples): use SMTP_HOST=smtp.gmail.com, seu e-mail em SMTP_USER e
# uma "Senha de app" de 16 dígitos em SMTP_PASSWORD (exige verificação em 2
# etapas — gere em https://myaccount.google.com/apppasswords). O remetente
# (SMTP_FROM) deve usar o MESMO endereço do SMTP_USER.
# Teste o envio com: npm run test:email seu-email@gmail.com
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Portal Logístico <voce@gmail.com>"

# ----- WhatsApp (Meta Cloud API) ------------------------------------------
# Se NÃO preenchido, as notificações de WhatsApp rodam em MODO SIMULADO.
# Obtenha estes valores no painel de desenvolvedores da Meta (Business).
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v21.0"
# Token usado para validar o webhook (opcional).
WHATSAPP_VERIFY_TOKEN="portal-logistico-webhook"

# ----- IA (Claude / Anthropic) para o módulo de Previsão ------------------
# Se NÃO preenchido, o Forecast usa o baseline estatístico local.
# Obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ----- Credenciais iniciais (usadas pelo seed) ----------------------------
# Super Admin = dono da plataforma (cria/gerencia organizações).
SEED_SUPERADMIN_EMAIL="super@portal.local"
SEED_SUPERADMIN_PASSWORD="super123"
# Admin da organização de demonstração (Plascar Demo).
SEED_ADMIN_EMAIL="admin@portal.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Administrador"
